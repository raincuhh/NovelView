{
   "name": "novelview",
   "version": "1.0.13-alpha.3",
   "description": "A cross-platform application that lets you save, and read your .epub, .azw, etc.. formats.",
   "main": "index.js",
   "scripts": {
      "dev": "vite",
      "build": "vite build",
      "tauri": "tauri",
      "tauri:dev": "npm run lint && tauri dev",
      "tauri:build": "tauri build",
      "lint": "eslint --fix",
      "test": "echo \"Error: no test specified\" && exit 1",
      "postversion": "git push && git push --tags",
      "version:bump": "npm version prerelease --preid=alpha",
      "push": "git add . && npm run version:bump && git add package.json package-lock.json && git commit -m \"chore(release): bump version to $(node -p 'require(\"./package.json\").version')\" && git tag v$(node -p 'require(\"./package.json\").version') && git push && git push --tags",
      "capacitor:android:live": "npx cap run android --livereload --external"
   },
   "repository": {
      "type": "git",
      "url": "git+https://github.com/raincuhh/NovelView.git"
   },
   "keywords": [
      "epub-reader",
      "epub",
      "azw",
      "pdf",
      "reader",
      "fullstack"
   ],
   "author": "Filip Ryan",
   "license": "MIT",
   "bugs": {
      "url": "https://github.com/raincuhh/NovelView/issues"
   },
   "homepage": "https://github.com/raincuhh/NovelView#readme",
   "type": "module",
   "devDependencies": {
      "@tauri-apps/cli": "^2.0.4",
      "@types/eslint": "^9.6.1",
      "@types/react": "^18.3.12",
      "@types/react-dom": "^18.3.1",
      "@typescript-eslint/eslint-plugin": "^8.16.0",
      "@typescript-eslint/parser": "^8.16.0",
      "@vitejs/plugin-react": "^4.3.3",
      "autoprefixer": "^10.4.20",
      "eslint": "^9.15.0",
      "eslint-define-config": "^2.1.0",
      "eslint-import-resolver-typescript": "^3.6.3",
      "eslint-plugin-boundaries": "^5.0.1",
      "eslint-plugin-import": "^2.31.0",
      "postcss": "^8.4.47",
      "prettier-plugin-classnames": "^0.7.4",
      "prettier-plugin-tailwindcss": "^0.6.8",
      "tailwindcss": "^3.4.14",
      "typescript": "^5.6.3",
      "vite": "^5.4.11"
   },
   "dependencies": {
      "@capacitor/android": "^6.1.2",
      "@capacitor/cli": "^6.1.2",
      "@capacitor/core": "^6.1.2",
      "@capacitor/filesystem": "^6.0.2",
      "@capacitor/ios": "^6.1.2",
      "@fortawesome/fontawesome-svg-core": "^6.6.0",
      "@fortawesome/free-brands-svg-icons": "^6.6.0",
      "@fortawesome/free-regular-svg-icons": "^6.6.0",
      "@fortawesome/free-solid-svg-icons": "^6.6.0",
      "@fortawesome/react-fontawesome": "^0.2.2",
      "@gsap/react": "^2.1.1",
      "@supabase/supabase-js": "^2.46.1",
      "@tauri-apps/api": "^2.0.3",
      "@tauri-apps/plugin-sql": "^2.0.2",
      "@tauri-apps/plugin-store": "^2.1.0",
      "@types/node": "^22.9.0",
      "axios": "^1.7.7",
      "bcrypt": "^5.1.1",
      "capacitor-secure-storage-plugin": "^0.10.0",
      "class-variance-authority": "^0.7.0",
      "clsx": "^2.1.1",
      "cors": "^2.8.5",
      "dotenv": "^16.4.5",
      "express": "^4.21.1",
      "gsap": "^3.12.5",
      "i18next": "^24.0.2",
      "jsonwebtoken": "^9.0.2",
      "mobile-detect": "^1.4.5",
      "motion": "^11.11.17",
      "react": "^18.3.1",
      "react-dom": "^18.3.1",
      "react-i18next": "^15.1.3",
      "react-loading-skeleton": "^3.5.0",
      "react-router-dom": "^6.27.0",
